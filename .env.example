# Hollywood — environment variables template
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored and must NEVER be committed.

# --- Supabase (client) ---
# These VITE_ vars are bundled into the browser. Safe to expose ONLY because
# Supabase Row Level Security (RLS) is what actually protects the data.
VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# --- Supabase (CLI / tooling only, NOT exposed to the browser) ---
SUPABASE_PROJECT_REF=your-project-ref-here
